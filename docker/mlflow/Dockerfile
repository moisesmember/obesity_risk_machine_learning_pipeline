FROM python:3.12-slim

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY docker/mlflow/requirements.txt /tmp/mlflow-requirements.txt

RUN python -m pip install --upgrade pip \
    && python -m pip install --requirement /tmp/mlflow-requirements.txt \
    && addgroup --system mlflow \
    && adduser --system --ingroup mlflow --home /home/mlflow mlflow \
    && rm /tmp/mlflow-requirements.txt

USER mlflow
WORKDIR /home/mlflow

EXPOSE 5000
