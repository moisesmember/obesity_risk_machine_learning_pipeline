{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Obesity risk model promotion policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_version", "model_name", "thresholds"],
  "properties": {
    "policy_version": {"type": "string", "minLength": 1},
    "model_name": {"type": "string", "minLength": 1},
    "require_human_approval": {"type": "boolean"},
    "require_mlflow_logged": {"type": "boolean"},
    "require_no_failed_candidates": {"type": "boolean"},
    "require_no_unavailable_candidates": {"type": "boolean"},
    "allowed_aliases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_holdout_macro_f1",
        "min_holdout_balanced_accuracy",
        "min_recall_per_class",
        "max_holdout_ordinal_mae",
        "max_cv_macro_f1_std",
        "max_gender_macro_f1_gap"
      ],
      "properties": {
        "min_holdout_macro_f1": {"type": "number", "minimum": 0, "maximum": 1},
        "min_holdout_balanced_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "min_recall_per_class": {"type": "number", "minimum": 0, "maximum": 1},
        "max_holdout_ordinal_mae": {"type": "number", "minimum": 0, "maximum": 6},
        "max_cv_macro_f1_std": {"type": "number", "minimum": 0, "maximum": 1},
        "max_gender_macro_f1_gap": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
