# Credencial fornecida pelo Kaggle. Nunca preencha este arquivo versionado.
KAGGLE_API_TOKEN=

# Alternativa legada, se exigida pela versão local do cliente Kaggle.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Contrato da fonte. Altere o hash somente após revisar e documentar uma nova versão.
OBESITY_DATASET_SLUG=jpkochar/obesity-risk-dataset
OBESITY_DATASET_FILENAME=obesity_level.csv
OBESITY_DATASET_EXPECTED_SHA256=04549179841220E7537EE9065FAC9CF9446C6368133882B7199A5618EA541EE6

# Diretórios opcionais; vazios usam os defaults data/raw e data/staging.
# OBESITY_DATASET_RAW_ROOT=
# OBESITY_DATASET_STAGING_ROOT=

# MinIO local. Os valores abaixo correspondem ao docker-compose de desenvolvimento.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATASET_BUCKET=obesity-risk-datasets
MINIO_DATASET_PREFIX=datasets/obesity_risk_dataset
MINIO_MLFLOW_BUCKET=obesity-risk-mlflow
MINIO_SECURE=false
MINIO_AUTO_CREATE_BUCKET=true

# Tracking local. As credenciais abaixo são apenas defaults de desenvolvimento.
POSTGRES_DB=mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_PORT=5432
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_PREFIX=artifacts
AWS_DEFAULT_REGION=us-east-1
MLFLOW_SERVER_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,mlflow:5000
MLFLOW_SERVER_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Modelagem inicial. Valores provisórios e centralizados para reprodutibilidade.
OBESITY_TEST_SIZE=0.20
OBESITY_VALIDATION_SIZE=0.20
OBESITY_RANDOM_STATE=42
OBESITY_FEATURE_SET_VERSION=v1
# OBESITY_MODELING_DATASET_PATH=
# OBESITY_MODELING_OUTPUT_ROOT=
